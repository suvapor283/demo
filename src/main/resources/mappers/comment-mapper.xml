<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.basic.domain.comment.dao.CommentDao">
    <insert id="save" parameterType="com.example.basic.domain.comment.entity.Comment"> <!-- 매개변수가 2개 이상이다. map-->
        INSERT INTO `comment`
            SET  articleId = #{articleId}
                , comm = #{comm}
    </insert>

    <select id="findByArticleId" parameterType="long" resultType="com.example.basic.domain.comment.entity.Comment"> <!-- 매개변수가 1개이다. 해당 매개변수 타입 지정-->
        SELECT * FROM `comment`
            WHERE articleId = #{articleId}
    </select>
</mapper>