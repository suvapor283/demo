<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.basic.domain.auth.dao.MemberDao">
    <insert id="save" parameterType="com.example.basic.domain.auth.entity.Member"> <!-- 매개변수가 2개 이상이다. map-->
        INSERT INTO `member`
            SET  username = #{username}
                , `password` = #{password}
                , `role` = IFNULL(#{role}, 'normal')
    </insert>

    <select id="loginCheck" parameterType="com.example.basic.domain.auth.entity.Member" resultType="com.example.basic.domain.auth.entity.Member">
        select * from `member`
        where username = #{username}
    </select>
</mapper>